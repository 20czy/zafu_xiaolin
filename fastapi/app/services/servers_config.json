{
  "mcpServers": {
    "puppeteer": {
      "enabled": false,
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-puppeteer"]
    },
    "amap-maps": {
            "enabled": "${ENABLE_AMAP_MCP}",
            "command": "npx",
            "args": [
                "-y",
                "@amap/amap-maps-mcp-server"
            ],
            "env": {
                "AMAP_MAPS_API_KEY": "${AMAP_MAPS_API_KEY}"
            }
    },
    "time": {
      "enabled": false,
      "command": "uvx",
      "args": [
        "mcp-server-time",
        "--local-timezone=America/New_York"
      ]
    },
    "weather": {
      "enabled": true,
      "command": "python",
      "cwd": "__fastapi_root__",
      "init_timeout": 5,
      "args": [
        "-m",
        "app.services.weather_mcp_server"
      ]
    },
    "zhipu-web-search-sse": {
      "enabled": "${ENABLE_ZHIPU_WEB_SEARCH_MCP}",
      "url": "https://open.bigmodel.cn/api/mcp/web_search/sse",
      "headers": {
        "Authorization": "Bearer ${ZHIPU_WEB_SEARCH_TOKEN}"
      }
    }
  }
}
